# Generate a random secret:
# https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=replace-with-random-secret

# The following keys below are automatically created and
# added to your environment when you deploy on Vercel

# Generate an Agnic API token from https://app.agnic.ai
AGNIC_API_KEY=replace-with-agnic-api-key

# Optional: override the Agnic OpenAI-compatible gateway URL
AGNIC_GATEWAY_BASE_URL=https://api.agnic.ai/v1


# Instructions to create a Vercel Blob Store here: https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=replace-with-vercel-blob-token

# Instructions to create a PostgreSQL database here: https://vercel.com/docs/postgres
POSTGRES_URL=postgres://user:password@localhost:5432/database


# Instructions to create a Redis store here:
# https://vercel.com/docs/redis
REDIS_URL=redis://localhost:6379
